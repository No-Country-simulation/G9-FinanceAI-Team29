-- V1__Initial_Setup.sql
-- Migración inicial para la base de datos de FinanceAI (PostgreSQL)

-- 1. Tabla: categorias
CREATE TABLE IF NOT EXISTS categorias (
    id SERIAL PRIMARY KEY,
    nombre VARCHAR(50) UNIQUE NOT NULL,
    descripcion VARCHAR(200),
    icono VARCHAR(50),
    color VARCHAR(7)
);

-- 2. Tabla: usuarios
CREATE TABLE IF NOT EXISTS usuarios (
    id VARCHAR(10) PRIMARY KEY,
    ingreso_mensual DECIMAL(12,2),
    deuda_mensual DECIMAL(12,2),
    nivel_endeudamiento DECIMAL(5,2),
    gasto_mensual_promedio DECIMAL(12,2),
    ahorro_mensual_estimado DECIMAL(12,2),
    porcentaje_gastos_ingreso DECIMAL(5,2),
    frecuencia_ahorro VARCHAR(20) CHECK (frecuencia_ahorro IN ('Alta', 'Media', 'Baja', 'Nunca')),
    perfil_financiero VARCHAR(30) CHECK (perfil_financiero IN ('Saludable', 'En observación', 'En riesgo')),
    fecha_registro TIMESTAMPTZ DEFAULT CURRENT_TIMESTAMP,
    activa BOOLEAN DEFAULT TRUE
);

-- 3. Tabla: transacciones
CREATE TABLE IF NOT EXISTS transacciones (
    id VARCHAR(10) PRIMARY KEY,
    usuario_id VARCHAR(10) NOT NULL,
    categoria_id INT NOT NULL,
    descripcion VARCHAR(255),
    monto DECIMAL(12,2) NOT NULL,
    moneda VARCHAR(3) DEFAULT 'USD',
    recurrente BOOLEAN DEFAULT FALSE,
    medio_pago VARCHAR(50),
    fecha DATE NOT NULL DEFAULT CURRENT_DATE,
    tipo VARCHAR(10) CHECK (tipo IN ('Ingreso', 'Gasto')) NOT NULL,
    origen VARCHAR(50) CHECK (origen IN ('Manual', 'API', 'CSV')),

    CONSTRAINT fk_transacciones_usuario FOREIGN KEY (usuario_id) REFERENCES usuarios(id) ON DELETE CASCADE,
    CONSTRAINT fk_transacciones_categoria FOREIGN KEY (categoria_id) REFERENCES categorias(id) ON DELETE RESTRICT
);

-- 4. Tabla: perfiles_historial
CREATE TABLE IF NOT EXISTS perfiles_historial (
    id SERIAL PRIMARY KEY,
    usuario_id VARCHAR(10) NOT NULL,
    perfil_predicho VARCHAR(30),
    perfil_real VARCHAR(30),
    probabilidad DECIMAL(5,4),
    fecha_analisis TIMESTAMPTZ DEFAULT CURRENT_TIMESTAMP,
    detalles JSONB,

    CONSTRAINT fk_perfiles_usuario FOREIGN KEY (usuario_id) REFERENCES usuarios(id) ON DELETE CASCADE
);

-- 5. Tabla: resumen_gastos
CREATE TABLE IF NOT EXISTS resumen_gastos (
    id SERIAL PRIMARY KEY,
    usuario_id VARCHAR(10) NOT NULL,
    categoria_id INT NOT NULL,
    total DECIMAL(12,2) NOT NULL DEFAULT 0.00,
    porcentaje DECIMAL(5,2),
    cantidad_transacciones INT DEFAULT 0,
    periodo_inicio DATE NOT NULL,
    periodo_fin DATE NOT NULL,

    CONSTRAINT fk_resumen_usuario FOREIGN KEY (usuario_id) REFERENCES usuarios(id) ON DELETE CASCADE,
    CONSTRAINT fk_resumen_categoria FOREIGN KEY (categoria_id) REFERENCES categorias(id) ON DELETE CASCADE
);

-- 6. Tabla: recomendaciones
CREATE TABLE IF NOT EXISTS recomendaciones (
    id SERIAL PRIMARY KEY,
    usuario_id VARCHAR(10) NOT NULL,
    texto VARCHAR(500) NOT NULL,
    prioridad VARCHAR(10) CHECK (prioridad IN ('Alta', 'Media', 'Baja')),
    categoria_recomendada VARCHAR(50),
    activa BOOLEAN DEFAULT TRUE,
    fecha_creacion TIMESTAMPTZ DEFAULT CURRENT_TIMESTAMP,

    CONSTRAINT fk_recomendaciones_usuario FOREIGN KEY (usuario_id) REFERENCES usuarios(id) ON DELETE CASCADE
);

-- Índices de optimización para acelerar las consultas de filtrado por usuario y fechas
CREATE INDEX idx_transacciones_usuario ON transacciones(usuario_id);
CREATE INDEX idx_transacciones_fecha ON transacciones(fecha);
CREATE INDEX idx_resumen_periodo ON resumen_gastos(usuario_id, periodo_inicio, periodo_fin);